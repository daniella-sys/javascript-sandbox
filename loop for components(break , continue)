let serverMemory = 40; //memory
for(let i = 1; i <= 10; i++){
      let passwordLength = i * 2;
      if(i === 4  || i === 7){
        continue;
      }else if(passwordLength <= 6){
        continue;
      }else if(serverMemory < passwordLength){
        console.log("Сервер перевантажено!");
        break;
      }else{
        serverMemory -= passwordLength;
        console.log("Пароль № " + i + " успішно перевірено");
      }
}
