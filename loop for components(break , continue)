let powerBank = 150;
for(let i = 1; i <= 10; i++){
  let q = 12 * i;
      if(i === 6 || i === 2){
        continue;
      
      }else if(q <= 30){
        powerBank -= q;
        continue;
        
      }else if(powerBank <= q){
        console.log("Робот розрядився");
        break;
      }else{
        powerBank -= q;
        console.log("Смартфон № " + i + " успішно протестовано");
      }
}

let inventory = 0;//(скільки дров уже зібрано)
let energy = 40;
for(let i = 1; i <= 10; i++){
  let drkk = i * 3; //кількість
      if(i === 3 || i === 9){
         continue;
        }else if(drkk >= 20){
          continue;
        }else if(energy <= drkk){
          console.log("Персонаж занадто втомився!");
          break;

        }else{
          energy -= drkk;
          inventory += drkk;
          console.log("Дерево № " + i + " зрубано!");
        }
}

